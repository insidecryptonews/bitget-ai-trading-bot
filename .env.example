BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_PASSPHRASE=
BITGET_BASE_URL=https://api.bitget.com
MARGIN_MODE=isolated
FORCE_ISOLATED_MARGIN=true
DISALLOW_CROSSED_MARGIN=true
AUTO_MARGIN=false

# Modos
PAPER_TRADING=true
LIVE_TRADING=false
DRY_RUN=true

# Capital
STARTING_CAPITAL_USDT=40

# Perfil
RISK_PROFILE=aggressive_small_account

# Riesgo
DEFAULT_LEVERAGE=3
MAX_LEVERAGE=5
MAX_RISK_PER_TRADE=0.025
MAX_DAILY_LOSS=0.08
MAX_WEEKLY_LOSS=0.18
MAX_MARGIN_USAGE_PER_TRADE=0.45
MAX_TOTAL_MARGIN_USAGE=0.75
MARGIN_SAFETY_BUFFER_USDT=1.0
MIN_FREE_MARGIN_AFTER_TRADE=0.20
MIN_STOP_DISTANCE_PCT=0.006
MAX_NOTIONAL_PER_TRADE_SMALL_ACCOUNT=120
MAX_OVER_NOTIONAL_DEVIATION_PCT=0.05
MAX_UNDER_NOTIONAL_DEVIATION_PCT=0.20
USE_FIXED_TRADE_MARGIN=true
TRADE_MARGIN_USDT=12.00
MAX_TRADE_MARGIN_USDT=15.00
MIN_TRADE_MARGIN_USDT=5.00
SMALL_ACCOUNT_MAX_OPEN_POSITIONS=1
MAX_OPEN_POSITIONS=1
ALLOW_SECOND_POSITION_SMALL_ACCOUNT=false
MAX_POSITIONS_PER_SYMBOL=1
MAX_CORRELATED_POSITIONS=1
MIN_SCORE_TO_TRADE=72
MIN_SCORE_EXCELLENT=85
MIN_SCORE_TO_ALERT=62
MIN_RISK_REWARD=1.4

# Escaneo
SCAN_INTERVAL_SECONDS=30
FAST_SCAN_INTERVAL_SECONDS=10
POSITION_MONITOR_INTERVAL_SECONDS=5
MAIN_TIMEFRAME=5m
CONFIRMATION_TIMEFRAME=15m
HIGHER_TIMEFRAME=1h

# Seguridad
ENABLE_CIRCUIT_BREAKERS=true
MAX_CONSECUTIVE_LOSSES=3
COOLDOWN_AFTER_LOSSES_MINUTES=180
REQUIRE_STOP_LOSS=true
REQUIRE_TAKE_PROFIT=true
CLOSE_IF_PROTECTION_FAILS=true
STOP_TRADING_BELOW_BALANCE_USDT=20

# Railway / DB
DATABASE_URL=
USE_POSTGRES_IF_AVAILABLE=true
PORT=8080

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Inteligencia de mercado opcional
ENABLE_NEWS_INTEL=false
NEWS_API_KEY=
SENTIMENT_API_KEY=

# Research Engine / Meta-model
ENABLE_FEATURE_LOGGING=true
ENABLE_SIGNAL_LABELING=true
ENABLE_META_MODEL=false
ENABLE_RESEARCH_AUTO_REPORT=true
RESEARCH_REPORT_INTERVAL_MINUTES=60
ENABLE_FULL_RESEARCH_AUTO_REPORT=true
FULL_RESEARCH_REPORT_INTERVAL_MINUTES=60
FULL_RESEARCH_REPORT_MODE=compact
FULL_RESEARCH_STARTUP_MODE=compact
FULL_RESEARCH_SECTION_TIMEOUT_SECONDS=10
FULL_RESEARCH_HEAVY_REPORT_ENABLED=false
META_MODEL_MIN_SAMPLES=300
META_MODEL_MIN_POSITIVES=50
META_MODEL_MIN_NEGATIVES=50
META_MIN_PROBABILITY=0.58
META_MODEL_MODE=observe_only
MAX_HOLDING_BARS=48
LABEL_USE_TP2=false

# Símbolos
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,XRPUSDT,DOGEUSDT,BNBUSDT,LINKUSDT,AVAXUSDT,ADAUSDT,DOTUSDT
